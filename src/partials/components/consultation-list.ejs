<!-- Parent container -->
<div>
  <!-- Header container with search bar and filters -->
  <div class="flex flex-col gap-4 md:gap-8">


    <!-- Search bar with sorting methods -->
    <div class="flex flex-col md:flex-row gap-4 md:gap-8">


      <!-- Search bar -->
      <div class="relative md:flex-1 w-full h-14">
        <!-- Search icon -->
        <span
          class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-tertiary"
        >
          search
        </span>

        <!-- Input field for searching consultations -->
        <input
          type="text"
          placeholder="Rechercher une consultation..."
          class="w-full h-full border-2 border-gray-300 rounded-xl pl-12 pr-4 focus:border-primary focus:outline-none"
        />
      </div>

      <!-- Filtre -->
      <div
        class="flex items-center gap-3 h-14 px-4 border-2 border-gray-300 rounded-xl"
      >
        <span class="material-symbols-outlined text-tertiary">
          filter_alt
        </span>

        <label for="sort" class="text-tertiary font-semibold whitespace-nowrap">
          Trier par :
        </label>

        <select
          id="sort"
          class="h-10 bg-transparent border border-gray-200 rounded-lg px-3 focus:border-primary focus:outline-none text-tertiary"
        >
          <option value="date">Plus récentes</option>
          <option value="title">Plus populaires</option>
          <option value="status">Plus anciennes</option>
        </select>
      </div>
    </div>


    <!-- Filters container -->
    <div class="flex flex-wrap items-center gap-4">
      <!-- Chip -->
      <div
        class="bg-primary text-white py-3 px-5 rounded-full text-sm font-semibold"
      >
        Tous (<%= consultations.length %>)
      </div>

      <!-- Chip -->
      <div
        class="border-1 border-green-600 bg-none text-green-600 py-3 px-5 rounded-full text-sm font-semibold"
      >
        En cours (<%= consultations.filter(c => c.statut === 1).length %>)
      </div>

      <!-- Chip -->
      <div
        class="border-1 border-yellow-500 bg-none text-yellow-500 py-3 px-5 rounded-full text-sm font-semibold"
      >
        À venir (<%= consultations.filter(c => c.statut === 0).length %>)
      </div>

      <!-- Chip -->
      <div
        class="border-1 border-purple-600 bg-none text-purple-600 py-3 px-5 rounded-full text-sm font-semibold"
      >
        Terminées (<%= consultations.filter(c => c.statut === 2).length %>)
      </div>
    </div>

    <!-- Consultation list container -->
    <div class="w-full flex-row flex-wrap gap-4 md:gap-6 flex grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 items-stretch">
      <% consultations.forEach(consultation => { %>
        <%- include("./consultation-card", { consultation }) %>
      <%}); %>
    </div>
  </div>
</div>
