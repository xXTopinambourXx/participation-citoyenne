<!-- Parent container -->
<div>
  <!-- Header container with search bar and filters -->
  <div class="flex flex-col gap-4 md:gap-8">


    <!-- Search bar with sorting methods -->
    <div class="flex flex-col sm:flex-row gap-4 md:gap-8">

      <!-- Search bar -->
      <div class="relative md:flex-1 w-full h-14">
        <!-- Search icon -->
        <span
          class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-tertiary"
        >
          search
        </span>

        <!-- Input field for searching consultations -->
        <input
          type="text"
          placeholder="Rechercher une consultation..."
          class="w-full h-full border-2 border-gray-300 rounded-xl pl-12 pr-4 focus:border-primary focus:outline-none"
        />
      </div>

      <!-- Filtre -->
      <div
        class="flex items-center gap-3 h-14 border-2 border-gray-300 rounded-xl justify-center px-2"
      >
        <span class="material-symbols-outlined text-tertiary max-[400px]:hidden">
          filter_alt
        </span>

        <label for="sort-select" class="text-tertiary font-semibold whitespace-nowrap max-[400px]:hidden">
          Trier par :
        </label>

        <select
          id="sort-select"
          class="h-10 bg-transparent border border-gray-200 rounded-lg px-3 focus:border-primary focus:outline-none text-tertiary"
        >
          <option value="recentes" selected>Plus récentes</option>
          <option value="populaires">Plus populaires</option>
          <option value="anciennes">Plus anciennes</option>
        </select>
      </div>
    </div>


    <!-- Filters container -->
    <% 
      // Pré-calcul des compteurs pour éviter les filtres à répétition
      const maintenant = Date.now();
      let nbEnCours = 0, nbAVenir = 0, nbTerminees = 0, nbAnnulees = 0, nbSuspendues = 0;

      for (const c of consultations) {
          if (c.statut === 3) nbAnnulees++;
          else if (c.statut === 2) nbSuspendues++;
          else if (c.statut === 1) {
              const debutMs = c.dateDebut * 1000;
              const finMs = c.dateFin * 1000;
              if (finMs > maintenant && debutMs <= maintenant) nbEnCours++;
              else if (debutMs > maintenant) nbAVenir++;
              else if (finMs <= maintenant) nbTerminees++;
          }
      }
      let totalFiltrees = nbEnCours + nbAVenir + nbTerminees + nbAnnulees + nbSuspendues;
    %>

    <div class="flex flex-wrap items-center gap-4" id="filtres-consultation">
      <!-- Tous -->
      <button
        data-filter="all"
        class="btn-active filter-btn text-blue-500 [&.btn-active]:bg-blue-500 [&.btn-active]:text-white hover:bg-blue-50 transition-colors"
      >
        Tous (<%= totalFiltrees %>)
      </button>

      <!-- À venir -->
      <button
        data-filter="a-venir"
        class="filter-btn text-yellow-500 [&.btn-active]:bg-yellow-500 [&.btn-active]:text-white hover:bg-yellow-50 transition-colors"
      >
        À venir (<%= nbAVenir %>)
      </button>

      <!-- En cours -->
      <button
        data-filter="en-cours"
        class="filter-btn text-green-500 [&.btn-active]:bg-green-500 [&.btn-active]:text-white hover:bg-green-50 transition-colors"
      >
        En cours (<%= nbEnCours %>)
      </button>

      <!-- Terminées -->
      <button
        data-filter="terminee"
        class="filter-btn text-purple-500 [&.btn-active]:bg-purple-500 [&.btn-active]:text-white hover:bg-purple-50 transition-colors"
      >
        Terminées (<%= nbTerminees %>)
      </button>

      <!-- Suspendues -->
      <button
        data-filter="suspendue"
        class="filter-btn text-gray-500 [&.btn-active]:bg-gray-500 [&.btn-active]:text-white hover:bg-gray-50 transition-colors"
      >
        Suspendues (<%= nbSuspendues %>)
      </button>

      <!-- Annulées -->
      <button
        data-filter="annulee"
        class="filter-btn text-red-500 [&.btn-active]:bg-red-500 [&.btn-active]:text-white hover:bg-red-50 transition-colors"
      >
        Annulées (<%= nbAnnulees %>)
      </button>
    </div>

    <!-- Le message d'alerte, caché par défaut grâce à 'hidden' -->
    <div id="no-consultations-message" class="hidden text-center py-8 text-gray-500 font-medium">
      Aucune consultation <span id="active-filter-label"></span>.
    </div>

    <!-- Consultation list container -->
    <div id="consultations-container" class="w-full flex-row flex-wrap gap-4 md:gap-6 flex grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 items-stretch">
      <% const consultationsFiltrees = consultations.filter(c => c.statut !== 4 && c.statut !== 0);
        const nbConsultations = consultationsFiltrees.length; 
      %>
      <% if (nbConsultations === 0) { %>
        <p class="text-center text-gray-500 col-span-full text-lg">
          Aucune consultation disponible.
        </p>
      <% } else { %>
        <% consultationsFiltrees.forEach(consultation => { %>
          <%- include("./consultation-card", { consultation }) %>
        <% }); %>
      <% } %>
    </div>
  </div>
</div>
