<div class="relative <%= bgColor %> px-6 py-4 md:py-6 md:px-8 rounded-xl flex justify-between items-center gap-4 md:gap-6 w-full overflow-hidden">
    <div class="flex flex-col items-start">
        <h1 class="text-black font-bold text-3xl md:text-5xl">
            <%= number %>
        </h1>

        <p class="<%= textColor %> text-md md:text-xl">
            <%= title %>
        </p>
    </div>

    <span class="material-symbols-outlined <%= iconColor %> text-3xl md:text-4xl absolute -bottom-6 -right-8 infocard <%= icon === 'schedule' ? 'rotate-[225deg]' : '' %>">
        <%= icon %>
    </span>
</div>